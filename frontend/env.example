# Leave empty to use the Vite dev proxy (recommended).
# Set to a full backend URL in production (e.g. https://your-api.onrender.com)
VITE_API_BASE_URL=

# Dev-only: where the Vite dev server should proxy /api to.
# Use this if your backend isn't on port 4000.
VITE_API_PROXY_TARGET=http://127.0.0.1:4000


